# ============================================================
# SkinProof — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ---- Supabase ------------------------------------------------
# Found in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Server-side only — never expose this to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---- AI / Vision API ----------------------------------------
# Used by /api/analyze-skin for skin photo analysis
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---- App -----------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Optional: Analytics ------------------------------------
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ============================================================
# Supabase Storage Setup (run once in Supabase dashboard)
# ============================================================
#
# Run this SQL in Supabase SQL Editor after applying schema.sql:
#
# -- Private bucket for user skin photos
# INSERT INTO storage.buckets (id, name, public, file_size_limit, allowed_mime_types)
# VALUES (
#   'skin-photos',
#   'skin-photos',
#   false,
#   10485760,  -- 10MB max
#   ARRAY['image/jpeg', 'image/jpg', 'image/png', 'image/webp', 'image/heic']
# );
#
# -- Public bucket for product images (admin-uploaded)
# INSERT INTO storage.buckets (id, name, public, file_size_limit, allowed_mime_types)
# VALUES (
#   'product-images',
#   'product-images',
#   true,
#   5242880,   -- 5MB max
#   ARRAY['image/jpeg', 'image/jpg', 'image/png', 'image/webp']
# );
#
# -- Private bucket for user avatars
# INSERT INTO storage.buckets (id, name, public, file_size_limit, allowed_mime_types)
# VALUES (
#   'avatars',
#   'avatars',
#   false,
#   2097152,   -- 2MB max
#   ARRAY['image/jpeg', 'image/jpg', 'image/png', 'image/webp']
# );
#
# -- RLS policies for skin-photos bucket
# CREATE POLICY "Users can upload their own photos"
# ON storage.objects FOR INSERT
# WITH CHECK (bucket_id = 'skin-photos' AND auth.uid()::text = (storage.foldername(name))[1]);
#
# CREATE POLICY "Users can view their own photos"
# ON storage.objects FOR SELECT
# USING (bucket_id = 'skin-photos' AND auth.uid()::text = (storage.foldername(name))[1]);
#
# CREATE POLICY "Users can delete their own photos"
# ON storage.objects FOR DELETE
# USING (bucket_id = 'skin-photos' AND auth.uid()::text = (storage.foldername(name))[1]);
